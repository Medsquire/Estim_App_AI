{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist/coreui-free-angular-admin-template/browser",
  "installCommand": "npm install",


  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
